{
  "private": true,
  "engines": {
    "node": ">=20.19.0"
  },
  "name": "with-tailwind",
  "packageManager": "yarn@1.22.19",
  "workspaces": [
    "apps/2048",
    "apps/destructurizator",
    "apps/devpulse",
    "apps/language",
    "apps/miner",
    "apps/pokedex",
    "apps/portfolio",
    "apps/snake",
    "apps/solitaire",
    "apps/visit-stat",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "clean": "turbo clean",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "lint-staged": "lint-staged",
    "generate:prisma": "cd packages/prisma && npx prisma generate",
    "postinstall": "if [ \"$SKIP_PRISMA\" != \"true\" ]; then yarn generate:prisma; fi"
  },
  "dependencies": {
    "@prisma/client": "^6.18.0"
  },
  "resolutions": {
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "prisma": "^6.19.3",
    "@prisma/client": "^6.19.3",
    "ts-api-utils": "^2.1.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.6",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "husky": "^9.1.7",
    "lint-staged": "^12.5.0",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "turbo": "^2.9.14"
  }
}
