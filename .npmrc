auto-install-peers = true
# Internal deps are declared as "@repo/foo": "*" (no workspace: protocol), which
# yarn linked automatically. This makes pnpm link them from the workspace by
# version range instead of trying to fetch @repo/* from the registry (404).
link-workspace-packages = true
# Don't fail the install on peer-dep mismatches — warn instead (matches the old
# --legacy-peer-deps behaviour). We use pnpm's default isolated node_modules so
# each app gets one physical copy per dependency version (e.g. pokedex on
# Mantine 7 and visit-stat on Mantine 8 don't cross-contaminate React context).
strict-peer-dependencies = false
