# Build caches and noise that bloat upload size — Vercel rebuilds these.
# NOTE: this file is read from the repo ROOT for EVERY project's build, so it
# must NOT ignore any app's source. Ignoring apps/<x> here strips that project's
# own files at build time, so `turbo run build` finds 0 packages and the build
# fails with a missing output directory. Keep this to universal artifacts only.
node_modules
.next
.turbo
.swc
.DS_Store
coverage

# Local env files
.env
.env.local
.env.*.local

# Editor / OS noise
.idea
.vscode
