# Other apps in the monorepo — devpulse doesn't depend on them at build time
# and shipping their sources just slows the upload. Workspace packages
# (@repo/*) live in packages/ and are resolved by yarn workspaces.
apps/2048
apps/destructurizator
apps/gantt-chart
apps/language
apps/miner
apps/pokedex
apps/portfolio
apps/rpg-game
apps/snake
apps/solitaire
