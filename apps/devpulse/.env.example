# Required — copy your Neon Postgres connection string from packages/prisma/.env
# (the same one portfolio uses).
POSTGRES_PRISMA_URL=

# Required — any long random string. Vercel Cron injects this as
# Authorization: Bearer ${CRON_SECRET}. Generate with:
#   openssl rand -hex 32
CRON_SECRET=

# Required — Auth.js JWT session secret. Generate with:
#   openssl rand -hex 32
AUTH_SECRET=

# Required — Google OAuth Client ID for the Google One Tap sign-in.
# Created in Google Cloud Console → APIs & Services → Credentials → OAuth client ID.
# Must include this app's origins in "Authorized JavaScript origins".
# Same value lives client-side (NEXT_PUBLIC_ prefix) for GSI initialization;
# the server reads it as the expected audience when verifying ID tokens.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
