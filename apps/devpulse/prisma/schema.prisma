// Schema lives inside the app so Vercel's standard Prisma postinstall flow
// handles engine bundling. Model definitions must stay in sync with
// packages/prisma/schema.prisma — that's where migrations are managed.
// To add/change a model: edit both schemas, then run prisma migrate dev
// from packages/prisma.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_PRISMA_URL")
}

model NewsItem {
  id           String   @id @default(cuid())
  url          String   @unique
  title        String
  excerpt      String?
  source       String
  category     String
  publishedAt  DateTime
  fetchedAt    DateTime @default(now())
  isPreRelease Boolean  @default(false)
  engagement   Int?
  tags         String[] @default([])
  summary      String?
  cleanedHtml  String?
  referrers    String[] @default([])

  @@index([publishedAt(sort: Desc)])
  @@index([category, publishedAt(sort: Desc)])
  @@index([isPreRelease, publishedAt(sort: Desc)])
  @@index([engagement(sort: Desc)])
  @@map("devpulse_news_item")
}

// A feed the cron fetches from. Curated entries (isBuiltIn=true) are seeded
// once and live forever; user-added entries reference the creator. Items
// reference this by name (not FK) so the news_item table stays denormalized.
model DevpulseSource {
  id              String   @id @default(cuid())
  name            String
  /// URL uniqueness enforced via partial indexes in migration — see
  /// packages/prisma/schema.prisma for the contract.
  url             String
  category        String
  weight          Int      @default(5)
  isBuiltIn       Boolean  @default(false)
  createdByUserId String?
  createdBy       DevpulseUser?            @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)
  preferences     DevpulseUserSourcePref[]
  createdAt       DateTime @default(now())
  failureCount    Int       @default(0)
  disabledAt      DateTime?

  @@index([isBuiltIn])
  @@index([url])
  @@map("devpulse_source")
}

model DevpulseUser {
  id              String                  @id @default(cuid())
  email           String                  @unique
  name            String?
  image           String?
  lastVisitAt     DateTime?
  showPreReleases Boolean                 @default(false)
  createdAt       DateTime                @default(now())
  addedSources    DevpulseSource[]
  preferences     DevpulseUserSourcePref[]
  savedItems      DevpulseSavedItem[]
  dismissedItems  DevpulseDismissedItem[]
  keywordBoosts   DevpulseKeywordBoost[]
  mutes           DevpulseMute[]
  readItems       DevpulseReadItem[]

  @@map("devpulse_user")
}

model DevpulseKeywordBoost {
  id        String       @id @default(cuid())
  userId    String
  label     String
  terms     String[]
  weight    Int          @default(3)
  createdAt DateTime     @default(now())
  user      DevpulseUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("devpulse_keyword_boost")
}

model DevpulseMute {
  id        String       @id @default(cuid())
  userId    String
  pattern   String
  createdAt DateTime     @default(now())
  user      DevpulseUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("devpulse_mute")
}

model DevpulseReadItem {
  id     String       @id @default(cuid())
  userId String
  url    String
  readAt DateTime     @default(now())
  user   DevpulseUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, url])
  @@index([userId, readAt(sort: Desc)])
  @@map("devpulse_read_item")
}

// Per-user toggle of a source. Absence = use default (enabled). A row with
// enabled=false means the user explicitly hid the source from their feed.
model DevpulseUserSourcePref {
  id       String         @id @default(cuid())
  userId   String
  sourceId String
  enabled  Boolean        @default(true)
  user     DevpulseUser   @relation(fields: [userId], references: [id], onDelete: Cascade)
  source   DevpulseSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@unique([userId, sourceId])
  @@map("devpulse_user_source_pref")
}

model DevpulseSavedItem {
  id        String       @id @default(cuid())
  userId    String
  url       String
  createdAt DateTime     @default(now())
  user      DevpulseUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, url])
  @@index([userId, createdAt(sort: Desc)])
  @@map("devpulse_saved_item")
}

model DevpulseDismissedItem {
  id        String       @id @default(cuid())
  userId    String
  url       String
  createdAt DateTime     @default(now())
  user      DevpulseUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, url])
  @@map("devpulse_dismissed_item")
}
