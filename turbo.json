{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "generate": {
      "cache": false,
      "outputs": ["generated/**", "node_modules/.prisma/**"]
    },
    "build": {
      "dependsOn": ["generate", "^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [
        ".next/**",
        "!.next/cache/**",
        "{outputDir}/**/*",
        "apps/gantt-chart/build/**",
        "apps/pokedex/generated/**/*"
      ]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "lint:fix": {
      "cache": false
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "typecheck": {
      "dependsOn": ["^typecheck", "generate", "^generate"],
      "inputs": ["$TURBO_DEFAULT$"]
    },
    "format": {
      "dependsOn": ["^format"]
    },
    "start": {
      "cache": false,
      "persistent": true
    }
  }
}
