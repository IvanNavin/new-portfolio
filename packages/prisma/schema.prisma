generator client {
  provider        = "prisma-client-js"
  output          = "./generated/prisma-client"
  binaryTargets   = ["native", "rhel-openssl-3.0.x"]
  // Enables `new PrismaClient({ adapter })` so apps that ship to serverless
  // (devpulse on Vercel Functions) can use @prisma/adapter-neon instead of
  // shipping the Linux engine .so. Apps that don't pass an adapter continue
  // to use the legacy engine path — no behaviour change for them.
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_PRISMA_URL")
}

model Pokemon {
  id              Int      @id @default(autoincrement())
  name            String
  name_clean      String
  abilities       String[]
  types           String[]
  img             String?
  base_experience Int
  height          Int
  weight          Int
  is_default      Boolean
  order           Int
  hp              Int
  attack          Int
  defense         Int
  special_attack  Int
  special_defense Int
  speed           Int

  @@map("pokedex_pokemon")
}

model User {
  id    String  @id @default(cuid())
  email String  @unique
  name  String?
  cards Card[]

  @@map("language_user")
}

model Card {
  id          String   @id @default(cuid())
  word        String
  translation String
  remembered  Boolean  @default(false)
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
  userId      String

  @@map("language_card")
}

model Apartment {
  id              String        @id @default(cuid())
  name            String
  startDate       DateTime
  endDate         DateTime?
  apartmentListId String
  apartmentList   ApartmentList @relation(fields: [apartmentListId], references: [id])

  @@map("apartment")
}

model ApartmentList {
  id         String      @id @default(cuid())
  name       String
  apartments Apartment[]
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@map("apartment_list")
}

model VisitStat {
  id         String   @id @default(cuid())
  domain     String
  path       String
  country    String?
  region     String?
  city       String?
  timeZone   String?
  latitude   Float?
  longitude  Float?
  ip         String
  userAgent  String
  referrer   String?
  language   String?
  deviceType String?
  timestamp  DateTime @default(now())
  sessionId  String?
  event      String   @default("pageview")
  extra      Json?

  @@index([domain, path, timestamp])
  @@map("visit_stat")
}

model NewsItem {
  id          String   @id @default(cuid())
  url         String   @unique
  title       String
  excerpt     String?
  source      String
  category    String
  publishedAt DateTime
  fetchedAt   DateTime @default(now())

  @@index([publishedAt(sort: Desc)])
  @@index([category, publishedAt(sort: Desc)])
  @@map("devpulse_news_item")
}
