generator client {
  provider        = "prisma-client-js"
  output          = "./generated/prisma-client"
  binaryTargets   = ["native", "rhel-openssl-3.0.x"]
  // Enables `new PrismaClient({ adapter })` so apps that ship to serverless
  // (devpulse on Vercel Functions) can use @prisma/adapter-neon instead of
  // shipping the Linux engine .so. Apps that don't pass an adapter continue
  // to use the legacy engine path — no behaviour change for them.
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_PRISMA_URL")
}

model Pokemon {
  id              Int      @id @default(autoincrement())
  name            String
  name_clean      String
  abilities       String[]
  types           String[]
  img             String?
  base_experience Int
  height          Int
  weight          Int
  is_default      Boolean
  order           Int
  hp              Int
  attack          Int
  defense         Int
  special_attack  Int
  special_defense Int
  speed           Int

  @@map("pokedex_pokemon")
}

model User {
  id    String  @id @default(cuid())
  email String  @unique
  name  String?
  cards Card[]

  @@map("language_user")
}

model Card {
  id          String   @id @default(cuid())
  word        String
  translation String
  remembered  Boolean  @default(false)
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
  userId      String

  @@map("language_card")
}

model VisitStat {
  id         String   @id @default(cuid())
  domain     String
  path       String
  country    String?
  region     String?
  city       String?
  timeZone   String?
  latitude   Float?
  longitude  Float?
  ip         String
  userAgent  String
  referrer   String?
  language   String?
  deviceType String?
  timestamp  DateTime @default(now())
  sessionId  String?
  event      String   @default("pageview")
  extra      Json?

  @@index([domain, path, timestamp])
  @@map("visit_stat")
}

model NewsItem {
  id           String   @id @default(cuid())
  url          String   @unique
  title        String
  excerpt      String?
  source       String
  category     String
  publishedAt  DateTime
  fetchedAt    DateTime @default(now())
  isPreRelease Boolean  @default(false)
  /// Engagement signal (HN points, Lobsters score). Null when the source
  /// doesn't expose one. Used by the Trending sort.
  engagement   Int?
  /// Match labels from KEYWORD_BOOSTS at ingest time. Surfaced as
  /// clickable tag chips on the card; filter by ?tag=label.
  tags         String[] @default([])
  /// AI-generated 1-2 sentence TLDR. Generated lazily at ingest via
  /// Google Gemini Flash (free tier) — null when generation failed
  /// or the model wasn't reachable; null cards just fall back to the
  /// excerpt rendering they always had.
  summary      String?
  /// Cleaned article HTML extracted via Mozilla Readability for the
  /// in-app reader drawer. Lazily fetched on first /api/article hit
  /// and cached. Null until a user actually opens the reader.
  cleanedHtml  String?
  /// Other sources that point to the same URL. Populated when a
  /// dedupe hit during ingest finds an existing row from a different
  /// feed — HN + Lobsters often share the same article. UI shows the
  /// extra sources as a "+ N more" pill.
  referrers    String[] @default([])

  @@index([publishedAt(sort: Desc)])
  @@index([category, publishedAt(sort: Desc)])
  @@index([isPreRelease, publishedAt(sort: Desc)])
  @@index([engagement(sort: Desc)])
  @@map("devpulse_news_item")
}

// Mirrors apps/devpulse/prisma/schema.prisma so migrations stay centralized
// here while the app keeps its own Prisma client (avoids workspace + Vercel
// File Tracing edge cases). Edit both schemas when changing any of the
// devpulse_* models below.

model DevpulseSource {
  id              String                   @id @default(cuid())
  name            String
  /// URL is unique per (createdByUserId, isBuiltIn) — enforced via a
  /// pair of partial indexes in the migration. Two users adding the
  /// same URL each get their own row with their own name, and we
  /// stop leaking "someone else added that feed" errors across users.
  url             String
  category        String
  weight          Int                      @default(5)
  isBuiltIn       Boolean                  @default(false)
  createdByUserId String?
  createdBy       DevpulseUser?            @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)
  preferences     DevpulseUserSourcePref[]
  createdAt       DateTime                 @default(now())
  /// Consecutive cron failures (HTTP error, parse error, timeout).
  /// Reset to 0 on every successful fetch. Used by the dead-source
  /// auto-disable logic.
  failureCount    Int                      @default(0)
  /// When the source got automatically disabled after too many
  /// consecutive failures. Null = healthy. Skipped by the cron until
  /// this is cleared manually.
  disabledAt      DateTime?

  @@index([isBuiltIn])
  @@index([url])
  @@map("devpulse_source")
}

model DevpulseUser {
  id              String                   @id @default(cuid())
  email           String                   @unique
  name            String?
  image           String?
  lastVisitAt     DateTime?
  showPreReleases Boolean                  @default(false)
  createdAt       DateTime                 @default(now())
  addedSources    DevpulseSource[]
  preferences     DevpulseUserSourcePref[]
  savedItems      DevpulseSavedItem[]
  dismissedItems  DevpulseDismissedItem[]
  keywordBoosts   DevpulseKeywordBoost[]
  mutes           DevpulseMute[]
  readItems       DevpulseReadItem[]

  @@map("devpulse_user")
}

/// User-defined keyword boost. Same shape as the curated KEYWORD_BOOSTS
/// in lib/keywords.ts; merged into the scoring pass at render time so
/// items matching personal keywords get bumped up within their day bucket.
model DevpulseKeywordBoost {
  id        String       @id @default(cuid())
  userId    String
  label     String
  terms     String[]
  weight    Int          @default(3)
  createdAt DateTime     @default(now())
  user      DevpulseUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("devpulse_keyword_boost")
}

/// Personal "hide anything matching this substring" pattern. Cheaper than
/// regex on the SQL side; matched case-insensitively against title +
/// excerpt at view time. Like dismiss × but proactive.
model DevpulseMute {
  id        String       @id @default(cuid())
  userId    String
  pattern   String
  createdAt DateTime     @default(now())
  user      DevpulseUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("devpulse_mute")
}

/// Marks an item as read without hiding it. Separate from dismiss: dismiss
/// is permanent "I never want to see this", read is "I already saw it".
/// The card shows a subtle desaturation when read.
model DevpulseReadItem {
  id     String       @id @default(cuid())
  userId String
  url    String
  readAt DateTime     @default(now())
  user   DevpulseUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, url])
  @@index([userId, readAt(sort: Desc)])
  @@map("devpulse_read_item")
}

model DevpulseUserSourcePref {
  id       String         @id @default(cuid())
  userId   String
  sourceId String
  enabled  Boolean        @default(true)
  user     DevpulseUser   @relation(fields: [userId], references: [id], onDelete: Cascade)
  source   DevpulseSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@unique([userId, sourceId])
  @@map("devpulse_user_source_pref")
}

model DevpulseSavedItem {
  id        String       @id @default(cuid())
  userId    String
  url       String
  createdAt DateTime     @default(now())
  user      DevpulseUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, url])
  @@index([userId, createdAt(sort: Desc)])
  @@map("devpulse_saved_item")
}

model DevpulseDismissedItem {
  id        String       @id @default(cuid())
  userId    String
  url       String
  createdAt DateTime     @default(now())
  user      DevpulseUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, url])
  @@map("devpulse_dismissed_item")
}
