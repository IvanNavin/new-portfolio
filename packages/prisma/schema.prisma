generator client {
  provider        = "prisma-client-js"
  output          = "./generated/prisma-client"
  binaryTargets   = ["native", "rhel-openssl-3.0.x"]
  // Enables `new PrismaClient({ adapter })` so apps that ship to serverless
  // (devpulse on Vercel Functions) can use @prisma/adapter-neon instead of
  // shipping the Linux engine .so. Apps that don't pass an adapter continue
  // to use the legacy engine path — no behaviour change for them.
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_PRISMA_URL")
}

model Pokemon {
  id              Int      @id @default(autoincrement())
  name            String
  name_clean      String
  abilities       String[]
  types           String[]
  img             String?
  base_experience Int
  height          Int
  weight          Int
  is_default      Boolean
  order           Int
  hp              Int
  attack          Int
  defense         Int
  special_attack  Int
  special_defense Int
  speed           Int

  @@map("pokedex_pokemon")
}

model User {
  id    String  @id @default(cuid())
  email String  @unique
  name  String?
  cards Card[]

  @@map("language_user")
}

model Card {
  id          String   @id @default(cuid())
  word        String
  translation String
  remembered  Boolean  @default(false)
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
  userId      String

  @@map("language_card")
}

model VisitStat {
  id         String   @id @default(cuid())
  domain     String
  path       String
  country    String?
  region     String?
  city       String?
  timeZone   String?
  latitude   Float?
  longitude  Float?
  ip         String
  userAgent  String
  referrer   String?
  language   String?
  deviceType String?
  timestamp  DateTime @default(now())
  sessionId  String?
  event      String   @default("pageview")
  extra      Json?

  @@index([domain, path, timestamp])
  @@map("visit_stat")
}

model NewsItem {
  id          String   @id @default(cuid())
  url         String   @unique
  title       String
  excerpt     String?
  source      String
  category    String
  publishedAt DateTime
  fetchedAt   DateTime @default(now())

  @@index([publishedAt(sort: Desc)])
  @@index([category, publishedAt(sort: Desc)])
  @@map("devpulse_news_item")
}

// Mirrors apps/devpulse/prisma/schema.prisma so migrations stay centralized
// here while the app keeps its own Prisma client (avoids workspace + Vercel
// File Tracing edge cases). Edit both schemas when changing any of the
// devpulse_* models below.

model DevpulseSource {
  id              String                   @id @default(cuid())
  name            String
  url             String                   @unique
  category        String
  weight          Int                      @default(5)
  isBuiltIn       Boolean                  @default(false)
  createdByUserId String?
  createdBy       DevpulseUser?            @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)
  preferences     DevpulseUserSourcePref[]
  createdAt       DateTime                 @default(now())

  @@index([isBuiltIn])
  @@map("devpulse_source")
}

model DevpulseUser {
  id             String                   @id @default(cuid())
  email          String                   @unique
  name           String?
  image          String?
  lastVisitAt    DateTime?
  createdAt      DateTime                 @default(now())
  addedSources   DevpulseSource[]
  preferences    DevpulseUserSourcePref[]
  savedItems     DevpulseSavedItem[]
  dismissedItems DevpulseDismissedItem[]

  @@map("devpulse_user")
}

model DevpulseUserSourcePref {
  id       String         @id @default(cuid())
  userId   String
  sourceId String
  enabled  Boolean        @default(true)
  user     DevpulseUser   @relation(fields: [userId], references: [id], onDelete: Cascade)
  source   DevpulseSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@unique([userId, sourceId])
  @@map("devpulse_user_source_pref")
}

model DevpulseSavedItem {
  id        String       @id @default(cuid())
  userId    String
  url       String
  createdAt DateTime     @default(now())
  user      DevpulseUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, url])
  @@index([userId, createdAt(sort: Desc)])
  @@map("devpulse_saved_item")
}

model DevpulseDismissedItem {
  id        String       @id @default(cuid())
  userId    String
  url       String
  createdAt DateTime     @default(now())
  user      DevpulseUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, url])
  @@map("devpulse_dismissed_item")
}
